{
  "__inputs": [
    {
      "name": "DS_INFINITY",
      "label": "GoPhish / SAT API (Infinity)",
      "description": "Infinity datasource pointed at your GoPhish or HailBytes SAT instance",
      "type": "datasource",
      "pluginId": "yesoreyeram-infinity-datasource",
      "pluginName": "Infinity"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "yesoreyeram-infinity-datasource",
      "name": "Infinity",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Phishing simulation metrics dashboard for GoPhish and HailBytes SAT. Requires the Infinity datasource plugin.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 20,
      "title": "Program Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
      "description": "Click rate per campaign over time. A declining trend indicates the program is working.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Click Rate %",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 6,
            "showPoints": "always",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Report Rate %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Click Rate %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "columns": [
            { "selector": "launch_date", "text": "Time", "type": "timestamp_epoch" },
            { "selector": "click_rate", "text": "Click Rate %", "type": "number" },
            { "selector": "report_rate", "text": "Report Rate %", "type": "number" },
            { "selector": "name", "text": "Campaign", "type": "string" }
          ],
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
          "filters": [],
          "format": "table",
          "global_query_id": "",
          "headers": [{ "key": "Authorization", "value": "Bearer ${api_key}" }],
          "method": "GET",
          "parser": "backend",
          "refId": "A",
          "root_selector": "",
          "source": "url",
          "type": "json",
          "url": "${gophish_host}/api/campaigns/",
          "url_options": { "data": "", "method": "GET" }
        }
      ],
      "title": "Click Rate & Report Rate Trend",
      "transformations": [
        { "id": "sortBy", "options": { "fields": [{ "desc": false, "displayName": "Time" }] } }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
      "description": "Current click rate vs. report rate across all completed campaigns. Goal: report rate > click rate.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "gradientMode": "none" },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 1 },
      "id": 2,
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "auto",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xField": "Campaign",
        "xTickLabelRotation": -45
      },
      "targets": [
        {
          "columns": [
            { "selector": "name", "text": "Campaign", "type": "string" },
            { "selector": "click_rate", "text": "Click Rate %", "type": "number" },
            { "selector": "report_rate", "text": "Report Rate %", "type": "number" }
          ],
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
          "filters": [],
          "format": "table",
          "headers": [{ "key": "Authorization", "value": "Bearer ${api_key}" }],
          "method": "GET",
          "parser": "backend",
          "refId": "A",
          "source": "url",
          "type": "json",
          "url": "${gophish_host}/api/campaigns/"
        }
      ],
      "title": "Click vs. Report Rate by Campaign",
      "type": "barchart"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
      "description": "Overall click rate across all campaigns. Green < 10%, yellow 10–20%, red > 20%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "/^Click Rate %$/", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "columns": [
            { "selector": "click_rate", "text": "Click Rate %", "type": "number" }
          ],
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
          "headers": [{ "key": "Authorization", "value": "Bearer ${api_key}" }],
          "method": "GET",
          "parser": "backend",
          "refId": "A",
          "source": "url",
          "type": "json",
          "url": "${gophish_host}/api/campaigns/"
        }
      ],
      "title": "Avg Click Rate (All Campaigns)",
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
      "description": "Average report rate across all campaigns. Should exceed click rate in a mature program.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 10 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 10 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "/^Report Rate %$/", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "columns": [
            { "selector": "report_rate", "text": "Report Rate %", "type": "number" }
          ],
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
          "headers": [{ "key": "Authorization", "value": "Bearer ${api_key}" }],
          "method": "GET",
          "parser": "backend",
          "refId": "A",
          "source": "url",
          "type": "json",
          "url": "${gophish_host}/api/campaigns/"
        }
      ],
      "title": "Avg Report Rate (All Campaigns)",
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
      "description": "Total number of phishing simulation recipients across all campaigns.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 10 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "/^Recipients$/", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "columns": [
            { "selector": "total_recipients", "text": "Recipients", "type": "number" }
          ],
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
          "headers": [{ "key": "Authorization", "value": "Bearer ${api_key}" }],
          "method": "GET",
          "parser": "backend",
          "refId": "A",
          "source": "url",
          "type": "json",
          "url": "${gophish_host}/api/campaigns/"
        }
      ],
      "title": "Total Recipients Tested",
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
      "description": "Total campaigns run.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 10 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["count"], "fields": "/^Campaign$/", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "columns": [
            { "selector": "name", "text": "Campaign", "type": "string" }
          ],
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
          "headers": [{ "key": "Authorization", "value": "Bearer ${api_key}" }],
          "method": "GET",
          "parser": "backend",
          "refId": "A",
          "source": "url",
          "type": "json",
          "url": "${gophish_host}/api/campaigns/"
        }
      ],
      "title": "Total Campaigns",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 21,
      "title": "Campaign Details",
      "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
      "description": "All campaigns with key metrics. Sort by Click Rate to identify your worst-performing campaigns.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Click Rate %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 10 },
                    { "color": "red", "value": 20 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Report Rate %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "green", "value": 10 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Click Rate %" }]
      },
      "targets": [
        {
          "columns": [
            { "selector": "name", "text": "Campaign", "type": "string" },
            { "selector": "status", "text": "Status", "type": "string" },
            { "selector": "launch_date", "text": "Launch Date", "type": "string" },
            { "selector": "total_recipients", "text": "Recipients", "type": "number" },
            { "selector": "clicks", "text": "Clicks", "type": "number" },
            { "selector": "click_rate", "text": "Click Rate %", "type": "number" },
            { "selector": "reports", "text": "Reports", "type": "number" },
            { "selector": "report_rate", "text": "Report Rate %", "type": "number" },
            { "selector": "template", "text": "Template", "type": "string" }
          ],
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_INFINITY}" },
          "headers": [{ "key": "Authorization", "value": "Bearer ${api_key}" }],
          "method": "GET",
          "parser": "backend",
          "refId": "A",
          "source": "url",
          "type": "json",
          "url": "${gophish_host}/api/campaigns/"
        }
      ],
      "title": "Campaign Summary",
      "transformations": [
        { "id": "sortBy", "options": { "fields": [{ "desc": true, "displayName": "Click Rate %" }] } }
      ],
      "type": "table"
    }
  ],
  "refresh": "1h",
  "schemaVersion": 38,
  "tags": ["phishing", "security", "gophish", "hailbytes-sat"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "GoPhish / SAT Host",
        "name": "gophish_host",
        "options": [
          {
            "selected": true,
            "text": "https://localhost:3333",
            "value": "https://localhost:3333"
          }
        ],
        "query": "https://localhost:3333",
        "description": "Base URL of your GoPhish or HailBytes SAT instance (no trailing slash)",
        "type": "textbox"
      },
      {
        "current": {},
        "hide": 2,
        "label": "API Key",
        "name": "api_key",
        "options": [],
        "query": "",
        "description": "GoPhish or SAT API key. Set hide=0 to show as a text input, or inject via Grafana environment variable.",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1y", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Phishing Simulation Metrics",
  "uid": "phishing-sim-metrics",
  "version": 1
}
